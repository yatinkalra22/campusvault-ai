# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB Table Names
DYNAMODB_ITEMS_TABLE=campusvault-items
DYNAMODB_PLACES_TABLE=campusvault-places
DYNAMODB_SHELVES_TABLE=campusvault-shelves
DYNAMODB_BORROWS_TABLE=campusvault-borrows
DYNAMODB_USERS_TABLE=campusvault-users
DYNAMODB_NOTIFICATIONS_TABLE=campusvault-notifications

# S3
S3_BUCKET_NAME=campusvault-images-dev
S3_PRESIGNED_URL_EXPIRY=3600

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your_client_id
COGNITO_REGION=us-east-1

# Nova / Bedrock Model IDs
NOVA_VISION_MODEL=amazon.nova-pro-v1:0
NOVA_TEXT_MODEL=amazon.nova-lite-v1:0
NOVA_EMBED_MODEL=amazon.nova-embed-v1:0

# App
PORT=3001
FRONTEND_URL=http://localhost:8081

# SES
SES_FROM_EMAIL=noreply@campusvault.dev
